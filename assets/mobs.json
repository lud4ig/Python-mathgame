############################ HEALTHBAR CODE #################################################

def display_health_bar(health, max_health):
    bar_length = 50  # Total length of the health bar
    filled_length = int(bar_length * health / max_health)
    bar = "[" + "=" * filled_length + " " * (bar_length - filled_length) + "]"
    return bar
    
